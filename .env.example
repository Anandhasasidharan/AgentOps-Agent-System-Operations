# AgentOps Platform — Environment Configuration
# Copy to .env and customize, or use defaults in docker-compose.yml

# Database
DATABASE_URL=postgresql+asyncpg://agentops:agentops@localhost:5432/agentops

# Default tenant slug used as X-API-Key for API calls
API_KEY=dev-api-key

# Service URLs (used by dashboard and inter-service calls)
CB_URL=http://circuit-breaker:8001
CHAOS_URL=http://chaos-toolkit:8002
SLO_URL=http://agent-slo-platform:8000

# OpenTelemetry exporter endpoint (SLO platform ingests OTLP)
OTEL_EXPORTER_ENDPOINT=http://agent-slo-platform:8000/v1/traces

# Logging
LOG_LEVEL=info
